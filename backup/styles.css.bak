:root {
  --bg: #f5f5f5;
  --text: #111;
  --muted: #666;
  --card: #fff;
  --border: #ddd;
  --accent: #111;
  --pill: #efefef;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: Arial, Helvetica, sans-serif;
  background: var(--bg);
  color: var(--text);
}

.site-header {
  background: #111;
  color: white;
  padding: 24px;
}

.site-header h1 {
  margin: 0;
  font-size: 28px;
}

.subtitle {
  margin-top: 6px;
  color: #ccc;
}

.page {
  max-width: 1200px;
  margin: 0 auto;
  padding: 24px;
}

.intro {
  margin-bottom: 24px;
}

.movies-container {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.movie-card {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 20px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
}

.poster-wrap img {
  width: 100%;
  display: block;
  border-radius: 8px;
}

.movie-title {
  margin: 0 0 8px;
  font-size: 28px;
}

.movie-meta {
  color: var(--muted);
  font-size: 16px;
  margin-bottom: 12px;
}

.movie-links {
  display: flex;
  gap: 12px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.btn {
  display: inline-block;
  padding: 10px 14px;
  border-radius: 8px;
  text-decoration: none;
  background: #111;
  color: white;
  font-size: 14px;
}

.schedule {
  width: 100%;
  border-collapse: collapse;
  margin-top: 10px;
}

.schedule th,
.schedule td {
  border: 1px solid var(--border);
  vertical-align: top;
  padding: 10px;
  width: 14.28%;
}

.schedule th {
  background: #fafafa;
  text-align: left;
  font-size: 14px;
}

.schedule-item {
  display: block;
  margin-bottom: 8px;
  padding: 8px;
  border-radius: 8px;
  background: var(--pill);
  text-decoration: none;
  color: #111;
  font-size: 14px;
}

.schedule-item:hover {
  background: #ddd;
}

.schedule-time {
  font-weight: bold;
}

.schedule-cinema {
  color: var(--muted);
  margin-left: 6px;
}

.empty {
  color: #999;
}

@media (max-width: 900px) {
  .movie-card {
    grid-template-columns: 1fr;
  }
}
